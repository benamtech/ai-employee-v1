# AMTECH local-machine production environment
# Copy to .env or populate the process environment from a secret manager.
# Never commit real values. Root pnpm scripts read this only as operator documentation;
# the existing production compose path uses mvp-build/infra/deploy/.env.production.

# Exact source identity. Root build/dev scripts derive this from git automatically.
AMTECH_GIT_SHA=DERIVED_FROM_GIT_HEAD
AMTECH_ENVIRONMENT_NAME=local-production
AMTECH_PUBLIC_DOMAIN=localhost

# Database / Supabase
DATABASE_URL=CHANGE_ME
STAGING_DATABASE_URL=CHANGE_ME
SUPABASE_URL=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# Manager and signed-resource authority
MANAGER_INTERNAL_TOKEN=CHANGE_ME
SIGNING_SECRET=CHANGE_ME
SECRET_REF_MASTER_KEY=CHANGE_ME
PROVISIONER_TOKEN=CHANGE_ME

# Model Gateway / commercial attribution
MODEL_GATEWAY_SIGNING_SECRET=CHANGE_ME
MODEL_GATEWAY_PROVIDER_API_KEY=CHANGE_ME
MODEL_GATEWAY_UPSTREAM_BASE_URL=CHANGE_ME
MODEL_GATEWAY_INPUT_CENTS_PER_MILLION=300
MODEL_GATEWAY_OUTPUT_CENTS_PER_MILLION=1500
MODEL_GATEWAY_MAX_RETRIES=2
MODEL_GATEWAY_PROVIDER_TIMEOUT_MS=30000

# Twilio
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_VERIFY_SERVICE_SID=CHANGE_ME
TWILIO_PHONE_NUMBER=CHANGE_ME

# Gmail / Google
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_PUBSUB_AUDIENCE=CHANGE_ME
GOOGLE_PUBSUB_SERVICE_ACCOUNT_EMAIL=CHANGE_ME

# Stripe
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME
STRIPE_CONNECT_CLIENT_ID=CHANGE_ME

# QuickBooks
QBO_CLIENT_ID=CHANGE_ME
QBO_CLIENT_SECRET=CHANGE_ME
QBO_WEBHOOK_VERIFIER_TOKEN=CHANGE_ME

# Local production budgets. Override only with an explicit machine profile and proof.
LOCAL_PROD_BUILD_BUDGET_SECONDS=30
LOCAL_PROD_BUILD_MAX_RSS_MB=4096
LOCAL_PROD_BUILD_MAX_ARTIFACT_MB=100
LOCAL_PROD_TEST_BUDGET_SECONDS=10
LOCAL_PROD_TEST_MAX_RSS_MB=4096
LOCAL_PROD_DEV_BUDGET_SECONDS=5
LOCAL_PROD_POSTGRES_IMAGE=postgres:17

# S8 bootstrap is deliberately disabled unless explicitly acknowledged for one command.
PLATFORM_ADMIN_BOOTSTRAP_ACK=
