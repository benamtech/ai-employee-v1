# ============================================================================
# AMTECH AI Employee MVP — environment (Phase 0)
# Copy to .env and fill. NEVER commit .env. Secrets are referenced, not logged.
# Current plan: ../wiki/MVP/build-plan-current/  ·  Original security packet: ../wiki/MVP/old-build-plan/10-security-ops-observability.md
# ============================================================================

# --- Runtime / hosting -------------------------------------------------------
NODE_ENV=development
# Public owner web surface (Next.js, runs on the VPS via `next start` behind Caddy)
PUBLIC_WEB_ORIGIN=https://amtechai.com
# Owner employee web route base (Caddy → manager/Hermes)
AGENT_WEB_ORIGIN=https://agent.amtechai.com
# Backend Manager API + webhook surface
MANAGER_API_ORIGIN=https://api.amtechai.com
MANAGER_PORT=8080
MANAGER_INTERNAL_TOKEN=change-me-internal-manager-token
PROVISIONER_ORIGIN=https://api.amtechai.com
PROVISIONER_TOKEN=change-me-provisioner-token
# Local no-SMS bootstrap only. Must be false/missing in production.
PROVISIONER_SKIP_SMS=false
# During laptop testing, the public URL the tunnel exposes (must match what Twilio signs)
PUBLIC_TUNNEL_URL=https://your-tunnel.example.com
PUBLIC_BASE_DOMAIN=amtechai.com

# --- Supabase (hosted: Postgres + Auth + Storage) ----------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase shared pooler connection string for migrations. Use the pooler URI
# locally because the direct db.<project>.supabase.co host can be IPv6-only.
DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@POOLER-HOST.supabase.com:6543/postgres
SUPABASE_STORAGE_BUCKET=artifacts
ARTIFACT_STORAGE_SIGNED_URL_SECONDS=300

# --- Twilio (account exists) -------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio Verify service SID (phone verification; works pre-A2P-campaign)
TWILIO_VERIFY_SERVICE_SID=
# A2P 10DLC (LONG LEAD — register Day 1; ~1-3 wk vetting). Dev uses the test number below.
TWILIO_A2P_BRAND_SID=
TWILIO_A2P_CAMPAIGN_SID=
TWILIO_MESSAGING_SERVICE_SID=
# Single 10DLC long code for dev/testing via tunnel (usable before campaign approval)
TWILIO_TEST_NUMBER=+1XXXXXXXXXX
TWILIO_EMPLOYEE_NUMBER=+1XXXXXXXXXX
# Reserved AMTECH front-door onboarding number (pool never recycles this)
TWILIO_FRONTDOOR_NUMBER=+1XXXXXXXXXX
# The exact public URL Twilio signs (set per environment; never disable signature in prod)
SMS_WEBHOOK_BASE_URL=https://api.amtechai.com/webhooks/twilio
# Local-debug ONLY. Never set true outside local. Bypasses X-Twilio-Signature.
SMS_INSECURE_NO_SIGNATURE=false

# --- Secret signing ----------------------------------------------------------
# HMAC key for single-use claim links + signed artifact links
SIGNING_SECRET=change-me-32+chars
# Secret-reference store master key (encrypts connector tokens at rest, Phase 3+)
SECRET_REF_MASTER_KEY=change-me-32+chars

# --- Hermes (Python engine on the VPS) --------------------------------------
HERMES_HOME=/home/amtech/.hermes
HERMES_BIN=hermes
# Base directory for per-client workspaces (~/amtech/clients/<id>/workspace)
AMTECH_CLIENTS_DIR=/home/amtech/amtech/clients
# Per-employee gateway ports start here (8100 + n)
HERMES_GATEWAY_PORT_BASE=8100
PROFILE_PACKAGES_DIR=
DEFAULT_PROFILE_PACKAGE=contractor_estimator
PROFILE_VALIDATION_COMMAND=node /home/amtech/GTM-RESEARCH/mvp-build/infra/scripts/profile-validate.mjs .
# Must start or restart the generated Hermes profile runtime. The provisioner
# fails closed if this is empty; use a real systemd/hermes wrapper in production.
HERMES_RUNTIME_COMMAND=
# Fallback only for local/dev runtimes without per-employee sealed API keys.
HERMES_API_TOKEN=
HERMES_TURN_TIMEOUT_MS=120000
# Production and production-like local/VPS testing default to Docker. Use `local`
# only as an explicit dev/demo fallback; it is not pilot-safe containment.
HERMES_BACKEND_TYPE=docker
CADDY_CLIENTS_DIR=/etc/caddy/clients
SYSTEMD_USER_DIR=/home/amtech/.config/systemd/user
AMTECH_MVP_ROOT=/home/amtech/GTM-RESEARCH/mvp-build
# Optional proof-script target. If empty, `npm run smoke:phase01` checks latest live employee.
SMOKE_EMPLOYEE_ID=

# --- Model providers (intelligence; not VPS-resident) ------------------------
# The front-door orchestrator uses an OpenAI-compatible Chat Completions workflow.
# To switch providers, change ORCHESTRATOR_API_BASE_URL + ORCHESTRATOR_API_KEY + ORCHESTRATOR_MODEL.
OPENAI_API_KEY=
XAI_API_KEY=
ORCHESTRATOR_API_BASE_URL=https://api.openai.com/v1
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_MODEL=gpt-4.1
ORCHESTRATOR_MAX_TOKENS=1200
ORCHESTRATOR_TEMPERATURE=0.2
# Default uses strict JSON Schema structured output. Use json_object or none only for
# OpenAI-compatible providers/models that reject json_schema response_format.
ORCHESTRATOR_RESPONSE_FORMAT=json_schema
# Example Grok switch:
# ORCHESTRATOR_API_BASE_URL=https://api.x.ai/v1
# ORCHESTRATOR_MODEL=grok-4.3
# XAI_API_KEY=your-xai-key
# ORCHESTRATOR_API_KEY can stay blank; XAI_API_KEY is used as a fallback.
# Employee runtime model keys can be supplied separately as Hermes/profile config needs.
ANTHROPIC_API_KEY=

# --- Gmail (Phase 3) ----------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.amtechai.com/webhooks/gmail/oauth/callback
GMAIL_PUBSUB_TOPIC=
# Authenticated Pub/Sub push verification (OIDC). The push subscription is created
# with an OIDC token whose audience = PUBSUB_VERIFICATION_AUDIENCE and whose service
# account = PUBSUB_SERVICE_ACCOUNT_EMAIL. pubsub.ts verifies issuer + audience +
# service-account email + RS256 signature (Google JWKS) + expiry. Set REQUIRE_AUTH
# to fail closed in production; leave audience blank only for local dev.
PUBSUB_VERIFICATION_AUDIENCE=
PUBSUB_SERVICE_ACCOUNT_EMAIL=
PUBSUB_REQUIRE_AUTH=true
# PUBSUB_JWKS_URL=  # optional override (default https://www.googleapis.com/oauth2/v3/certs)

# --- Stripe (Phase 4 GROUNDWORK — test mode account now, unused in Phase 0/1) -
STRIPE_SECRET_KEY=sk_test_
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_MODE=test
# Owner-app origin used for Stripe account-link return/refresh URLs (falls back to MANAGER_API_ORIGIN).
WEB_APP_ORIGIN=https://app.amtechai.com

# --- Owner SMS + Phase 5 scheduler --------------------------------------------
# Employee -> owner SMS (event notices + fired reminders). Set ONE of these; if
# neither is set the message still appears on the Work Surface (status pending).
EMPLOYEE_SMS_FROM=+1XXXXXXXXXX
# TWILIO_MESSAGING_SERVICE_SID is the alternative sender (see Twilio block above).
#
# Reminder firing, Gmail-watch renewal, and [SILENT] daily briefs are driven by
# Hermes Jobs in prod. `npm run scheduler:tick` remains the dev/cron fallback.
MANAGER_BASE_URL=http://localhost:8080
REMINDER_RENEW_WINDOW_SECONDS=86400
WEB_PRESENCE_WINDOW_SECONDS=90
SMS_PRESENCE_WINDOW_MINUTES=10
