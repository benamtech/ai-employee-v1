# =============================================================================
# AMTECH AI Employee — LOCAL VPS-faithful stack (Docker + Caddy, NO SMS)
# -----------------------------------------------------------------------------
# This file is SOURCED into your shell for the Manager + local scripts:
#   cp .env.local.example .env      # then fill the two <-- PASTE markers
#   set -a && source .env && set +a # (run from the mvp-build dir)
# The web app reads apps/web/.env.local separately (see apps/web/.env.local.example).
# =============================================================================

NODE_ENV=development

# Absolute path to THIS mvp-build dir. Defaults to your current dir when sourced
# from mvp-build; used by the provisioner + the Docker runtime wrapper.
AMTECH_MVP_ROOT="${AMTECH_MVP_ROOT:-$PWD}"

# --- Local origins -----------------------------------------------------------
PUBLIC_WEB_ORIGIN=http://localhost:3000
AGENT_WEB_ORIGIN=http://localhost:3000
MANAGER_API_ORIGIN=http://localhost:8080
MANAGER_BASE_URL=http://localhost:8080
MANAGER_PORT=8080
MANAGER_INTERNAL_TOKEN=dev-manager-internal-token-change-me
PROVISIONER_ORIGIN=http://localhost:8080
PROVISIONER_TOKEN=dev-provisioner-token-change-me
PUBLIC_BASE_DOMAIN=agents.localhost

# --- Supabase (project: amtech-ai-employee-mvp / uxuruijrgghshfwnaagb) --------
SUPABASE_URL=https://uxuruijrgghshfwnaagb.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV4dXJ1aWpyZ2doc2hmd25hYWdiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxMjc4OTQsImV4cCI6MjA5ODcwMzg5NH0.7qoWOlxj6vocL-a8vrrKs5twXsJK6RvF8kyz-Wiex_8
SUPABASE_SERVICE_ROLE_KEY=            # <-- PASTE from Supabase dashboard: Settings → API → service_role
DATABASE_URL=                         # <-- PASTE from Supabase dashboard: Settings → Database → Connection string (URI)
SUPABASE_STORAGE_BUCKET=artifacts
ARTIFACT_STORAGE_SIGNED_URL_SECONDS=300

# --- Signing / secret-ref (dev values; must be 32+ chars) --------------------
SIGNING_SECRET=dev-signing-secret-please-change-me-32chars
SECRET_REF_MASTER_KEY=dev-secret-ref-master-key-change-me-32chars

# --- Hermes runtime (Docker backend — the VPS-faithful path) -----------------
HERMES_BACKEND_TYPE=docker
HERMES_DOCKER_IMAGE=hermes-agent
# Seed home: a working Hermes home with model/provider config + keys. Each
# employee container copies its config.yaml + provider keys from here.
HERMES_SEED_HOME="$HOME/.hermes"
# Where rendered profiles are written (renderProfilePackage → HERMES_HOME/profiles/<id>).
HERMES_HOME="$HOME/amtech-local/render"
# Per-employee isolated Hermes homes + workspaces.
AMTECH_CLIENTS_DIR="$HOME/amtech-local/clients"
HERMES_GATEWAY_PORT_BASE=8100
# The per-employee Docker runtime starter (this repo).
HERMES_RUNTIME_COMMAND="bash $AMTECH_MVP_ROOT/infra/scripts/hermes-runtime-docker.sh"
PROFILE_VALIDATION_COMMAND="node $AMTECH_MVP_ROOT/infra/scripts/profile-validate.mjs ."
# Caddy per-client snippet dir (imported from your local Caddyfile).
CADDY_CLIENTS_DIR="$HOME/amtech-local/caddy/clients"

# --- No SMS locally (dev-only; both flags are ignored when NODE_ENV=production)
# Skip the provisioner's Twilio webhook + first SMS:
PROVISIONER_SKIP_SMS=1
# Run the FULL phone-verify flow (send-code → enter-code → check-code) but stub
# the Twilio Verify API call; any code equal to TWILIO_VERIFY_DEV_CODE passes.
TWILIO_VERIFY_DEV_BYPASS=1
TWILIO_VERIFY_DEV_CODE=000000

# --- Provider: OpenRouter as AMTECH's master account -------------------------
# One OpenRouter account fronts many upstream models, for both the front-door
# orchestrator AND the employee's Hermes model. Put the AMTECH OpenRouter key
# here; today you can reuse the key already in ~/.hermes/.env for testing.
OPENROUTER_API_KEY=            # <-- PASTE your OpenRouter key (sk-or-...)

# Front-door onboarding orchestrator (REQUIRED for the onboarding flow). Uses an
# OpenAI-compatible Chat Completions call against OpenRouter. json_object is the
# safe response format for free/varied models (the parser tolerates it).
ORCHESTRATOR_API_BASE_URL=https://openrouter.ai/api/v1
ORCHESTRATOR_API_KEY=          # optional; falls back to OPENROUTER_API_KEY above
ORCHESTRATOR_MODEL=openrouter/auto
ORCHESTRATOR_RESPONSE_FORMAT=json_object
# Free options to try if you don't want to spend credits (may be rate-limited):
#   ORCHESTRATOR_MODEL=openai/gpt-oss-120b:free
#   ORCHESTRATOR_MODEL=openrouter/free            # OpenRouter's free auto-router
