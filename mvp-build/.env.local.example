# =============================================================================
# AMTECH AI Employee - LOCAL VPS-faithful stack (Docker + Caddy, NO SMS)
# -----------------------------------------------------------------------------
# Copy to .env, fill the paste markers, then source it from mvp-build:
#   cp .env.local.example .env
#   set -a && source .env && set +a
#
# Local flow:
#   npm run db:migrate
#   npm run manager:dev
#   npm run local:bootstrap
#   npm run local:chat -- "Can you help price a small interior paint job?"
# =============================================================================

NODE_ENV=development

# --- Local origins -----------------------------------------------------------
PUBLIC_WEB_ORIGIN=http://localhost:3000
AGENT_WEB_ORIGIN=http://localhost:3000
MANAGER_API_ORIGIN=http://localhost:8080
MANAGER_BASE_URL=http://localhost:8080
MANAGER_PORT=8080
MANAGER_INTERNAL_TOKEN=local-manager-token-change-me
PROVISIONER_ORIGIN=http://localhost:8080
PROVISIONER_TOKEN=local-provisioner-token-change-me
PUBLIC_BASE_DOMAIN=localhost

# --- Supabase hosted project: amtech-ai-employee-mvp -------------------------
# Paste from Project Settings -> API. This is an EXAMPLE — never commit real keys here.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=PASTE_SUPABASE_ANON_OR_PUBLISHABLE_KEY
# Paste the Supabase service_role key from Project Settings -> API (secret; keep in .env only).
SUPABASE_SERVICE_ROLE_KEY=PASTE_SUPABASE_SERVICE_ROLE_KEY

# Paste the Supabase shared pooler connection string from Project Settings -> Database.
# Local IPv4-only networks cannot use the direct db.<ref>.supabase.co URI without
# Supabase's paid IPv4 path.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASTE_DB_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres
SUPABASE_STORAGE_BUCKET=artifacts
ARTIFACT_STORAGE_SIGNED_URL_SECONDS=300

# --- Local no-SMS mode -------------------------------------------------------
# This skips only Twilio webhook assignment + first outbound SMS.
# Provisioning still renders a per-employee profile, writes Caddy config, starts
# a per-employee Dockerized Hermes runtime, and points runtime_endpoints at it.
# It is rejected when NODE_ENV=production.
PROVISIONER_SKIP_SMS=1
SMS_INSECURE_NO_SIGNATURE=false
# Local/dev phone-verify bypass: lets the REAL front-door path (onboard.mjs /
# 06-browser-onboard.mjs) verify a phone without live Twilio + SMS. Fails closed
# in production. Put real Twilio creds (SID/token/test numbers) only in .env.
TWILIO_VERIFY_DEV_BYPASS=1
TWILIO_VERIFY_DEV_CODE=000000
# Local/dev owner "login": lets /api/dev/login?employeeId=<id> mint an owner web
# session + set the amtech_owner_session cookie so you can test the Work Surface of
# ANY existing employee without the (Phase 1 stub) Supabase Auth login. Manager AND
# web both read this. Fails closed when NODE_ENV=production.
DEV_OWNER_LOGIN=1
# Business identity below seeds the BYPASS bootstrap. Leave LOCAL_BUSINESS_* /
# LOCAL_OWNER_NAME / LOCAL_EMPLOYEE_NAME unset to let local:bootstrap and
# local:onboard pick a varied contractor fixture (ONBOARD_FIXTURE=<kind|index> pins one).
LOCAL_OWNER_NAME=Ben
LOCAL_OWNER_EMAIL=local-owner@example.com
LOCAL_OWNER_PASSWORD=local-password-change-me
LOCAL_OWNER_PHONE_E164=+15555550123
LOCAL_BUSINESS_DISPLAY_NAME="Local AMTECH Painting"
LOCAL_BUSINESS_KIND=painting
LOCAL_EMPLOYEE_NAME=Casey
LOCAL_TIMEZONE=America/New_York

# --- Secret signing ----------------------------------------------------------
SIGNING_SECRET=local-signing-secret-change-me-32chars
SECRET_REF_MASTER_KEY=local-secret-ref-master-key-change-me-32chars

# --- Hermes / runtime --------------------------------------------------------
HERMES_HOME=/home/georgej/.hermes
HERMES_BIN=hermes
AMTECH_CLIENTS_DIR=/tmp/amtech-local/clients
HERMES_GATEWAY_PORT_BASE=8100
DEFAULT_PROFILE_PACKAGE=contractor_estimator
PROFILE_VALIDATION_COMMAND="node /home/georgej/AMTECH/GTM-RESEARCH/mvp-build/infra/scripts/profile-validate.mjs ."
# Starts one Docker container per rendered employee profile.
HERMES_RUNTIME_COMMAND="bash /home/georgej/AMTECH/GTM-RESEARCH/mvp-build/infra/scripts/local/start-hermes-container.sh"
HERMES_DOCKER_IMAGE=hermes-agent
HERMES_API_TOKEN=local-hermes-dev-key-change-me
HERMES_TURN_TIMEOUT_MS=120000
HERMES_BACKEND_TYPE=docker
CADDY_CLIENTS_DIR=/tmp/amtech-local/caddy/clients
AMTECH_MVP_ROOT=/home/georgej/AMTECH/GTM-RESEARCH/mvp-build

# --- Local no-key model bridge (you-are-the-LLM) -----------------------------
# The live-test toolkit (infra/scripts/local/test/*, `npm run live:up`) exports
# these so BOTH the front-door orchestrator AND newly provisioned employees route
# their model calls through the agent-in-the-loop bridge, answered by one warm
# Claude Code Haiku worker. Employees: HERMES_MODEL_PROVIDER makes the renderer
# emit a custom-provider model block (base_url below) instead of claude-opus-4-8.
# Unset all of these for a real funded-key run. See infra/local/agent-model-bridge.md.
HERMES_MODEL_PROVIDER=custom
HERMES_MODEL_BASE_URL=http://host.docker.internal:8091/v1
HERMES_MODEL_DEFAULT=bridge-agent

# --- Model provider for front-door orchestrator ------------------------------
ORCHESTRATOR_API_BASE_URL=https://api.openai.com/v1
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_MODEL=gpt-4.1
ORCHESTRATOR_MAX_TOKENS=1200
ORCHESTRATOR_TEMPERATURE=0.2
ORCHESTRATOR_RESPONSE_FORMAT=json_schema
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
