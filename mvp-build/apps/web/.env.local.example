# AMTECH web (Next.js) — local env. Copy to apps/web/.env.local (Next auto-loads it).
# The web app is a thin proxy to the Manager; it holds NO Supabase keys.
# MANAGER_INTERNAL_TOKEN must match the Manager's value in the root .env.
MANAGER_API_ORIGIN=http://localhost:8080
MANAGER_INTERNAL_TOKEN=dev-manager-internal-token-change-me
