{
  "schema": "amtech.computed-decision.v1",
  "status": "active",
  "scope": "mvp-build non-mechanical planning and implementation decisions",
  "order": [
    "authority_extraction",
    "evidence_unknown_matrix",
    "tier_selection",
    "independent_candidate_batches",
    "feasibility_invariant_filter",
    "computed_comparison",
    "multiway_dependency_analysis_when_justified",
    "selected_exploration",
    "coherent_implementation_compression",
    "red_behavioral_proof",
    "implementation",
    "exact_head_verification",
    "documentation_handoff_update"
  ],
  "tiers": {
    "T0_mechanical": {
      "minimum_candidates": 1,
      "minimum_batches": 1,
      "required": ["authority_check", "protected_invariant", "exact_verification"],
      "graph": "not_required"
    },
    "T1_bounded": {
      "minimum_candidates": 4,
      "minimum_batches": 2,
      "required": ["evidence_labels", "feasibility_filter", "rejection_reasons", "implementation_choice"],
      "graph": "only_if_genuinely_multiway"
    },
    "T2_consequential": {
      "minimum_candidates": 16,
      "minimum_batches": 3,
      "required": ["weighted_dimensions", "utility_only_comparison", "separate_implementation_compression", "behavioral_failure_manifold"],
      "graph": "hypergraph_or_dependency_matrix_when_pairwise_loses_information"
    },
    "T3_production_cross_workstream": {
      "minimum_candidates": 64,
      "minimum_batches": 4,
      "batch_names": ["current", "feature", "counterfactual", "recombination"],
      "minimum_random_baselines": 100,
      "required": ["explicit_basis", "observed_unknown_reconciliation", "weighted_dimensions", "sparse_multiway_graph", "joint_utility_diversity_random_comparison", "graph_causality_classification", "separate_implementation_compression", "behavioral_failure_manifold"],
      "graph": "required_unless_pairwise_sufficiency_is_proved"
    }
  },
  "possible_spaces": [
    "bug",
    "feature",
    "user",
    "operator",
    "architecture",
    "protocol",
    "commercial",
    "failure",
    "proof",
    "market",
    "weird",
    "constraint"
  ],
  "evidence_labels": ["Observed", "Inferred", "Hypothesis", "Unknown", "NotApplicable"],
  "candidate_dimensions": [
    "Applicability",
    "Transfer",
    "Evidence",
    "CrossLens",
    "Unsupported",
    "BusinessValue",
    "VerificationFeasibility",
    "ProofDensity",
    "Reversibility",
    "ArchitectureLeverage",
    "RiskReduction",
    "Cost",
    "Scope",
    "PrerequisiteDebt",
    "OperatorBurden",
    "FutureOptionality"
  ],
  "default_joint_objective": {
    "q_bar": 0.3,
    "required_space_coverage": 0.2,
    "weighted_hyperedge_coverage": 0.1,
    "minimum_separation": 0.1,
    "mean_separation": 0.1,
    "normalized_von_neumann_entropy": 0.1,
    "quality_diversity_occupancy": 0.1,
    "redundancy": -0.15
  },
  "required_comparisons_T2_T3": ["joint", "utility_only", "diversity_dependency_only", "feasible_random"],
  "graph_causality": {
    "causal": "materially changes selected candidates, required coverage, feasibility, or coherent implementation compression",
    "descriptive": "does not materially change the decision and cannot justify added complexity"
  },
  "mathematics_guards": {
    "hypergraph": "use for genuine multiway dependencies",
    "hodge": "use only for a true simplicial complex",
    "koopman": "use only with repeated comparable trajectories, fitted propagation, held-out error, and diversity/residual control",
    "unknown": "never coerce to observed, zero risk, or positive evidence"
  },
  "implementation_compression": {
    "must_be_separate_from_exploration": true,
    "must_preserve_invariants": true,
    "must_have_behavioral_proof_or_honest_blocker": true,
    "must_avoid_parallel_ontology_or_runtime": true,
    "must_minimize_unrelated_scope": true
  },
  "required_trace_artifacts_T2_T3": [
    "task_state.json",
    "thought_templates.json",
    "candidate_population.json",
    "candidate_scores.json",
    "hypergraph.json_or_dependency_matrix.json",
    "selection_comparison.json",
    "selected_exploration.json",
    "selected_implementation.json",
    "counterexample_matrix.json",
    "implementation_contract.json",
    "verification_plan.json",
    "decision_record.md",
    "deterministic_verifier"
  ],
  "evidence_nonpromotion": [
    "computation",
    "documentation",
    "source",
    "unit",
    "integration",
    "ci",
    "provider",
    "managed_database",
    "target_host",
    "browser_channel",
    "commercial",
    "pilot",
    "deployment",
    "production"
  ]
}
