{
  "schema": "amtech.computed-decision.v1",
  "protocol_revision": 3,
  "status": "active",
  "scope": "mvp-build non-mechanical planning and implementation decisions",
  "order": [
    "authority_extraction",
    "evidence_unknown_matrix",
    "tier_selection",
    "independent_candidate_batches",
    "feasibility_invariant_filter",
    "explicit_baseline_semantics",
    "simple_evidence_invariants_baseline",
    "candidate_search_topology",
    "software_invariant_topology",
    "equal_feasibility_comparison",
    "weight_and_search_sensitivity",
    "selected_exploration",
    "coherent_implementation_compression",
    "complete_behavioral_proof_plan",
    "red_green_refactor",
    "exact_head_and_external_verification",
    "documentation_handoff_update"
  ],
  "tiers": {
    "T0_mechanical": {
      "minimum_candidates": 1,
      "minimum_batches": 1,
      "required": ["authority_check", "protected_invariant", "exact_verification"],
      "topology": "none"
    },
    "T1_bounded": {
      "minimum_candidates": 4,
      "minimum_batches": 2,
      "required": ["evidence_labels", "feasibility_filter", "rejection_reasons", "implementation_choice"],
      "topology": "only_when_it_changes_a_material_decision"
    },
    "T2_consequential": {
      "minimum_candidates": 16,
      "minimum_batches": 3,
      "minimum_search_restarts": 8,
      "minimum_weight_sensitivity_runs": 8,
      "required": [
        "weighted_dimensions",
        "explicit_baseline_roles_and_orientation",
        "simple_baseline",
        "equal_feasibility_controls",
        "separate_implementation_compression",
        "behavioral_failure_manifold"
      ]
    },
    "T3_production_cross_workstream": {
      "minimum_candidates": 64,
      "minimum_batches": 4,
      "batch_names": ["current", "feature", "counterfactual", "recombination"],
      "minimum_random_feasible_baselines": 1000,
      "minimum_search_restarts": 32,
      "minimum_weight_sensitivity_runs": 32,
      "required": [
        "explicit_basis",
        "observed_unknown_reconciliation",
        "explicit_baseline_roles_orientation_and_groups",
        "candidate_graph",
        "software_invariant_hypergraph",
        "touch_fractional_complete_proved_coverage",
        "equal_feasibility_full_no_graph_no_diversity_evidence_controls",
        "search_sensitivity",
        "weight_sensitivity",
        "implementation_ablation_or_noncausal_classification",
        "separate_implementation_compression",
        "complete_behavioral_proof_plan"
      ]
    }
  },
  "possible_spaces": [
    "bug",
    "feature",
    "user",
    "operator",
    "architecture",
    "protocol",
    "commercial",
    "failure",
    "proof",
    "market",
    "weird",
    "constraint"
  ],
  "evidence_labels": ["Observed", "Inferred", "Hypothesis", "Unknown", "NotApplicable"],
  "candidate_dimensions": [
    "IG",
    "BV",
    "N",
    "Adj",
    "CrossLens",
    "FutureBug",
    "FeatureYield",
    "ArchLeverage",
    "VF",
    "Testability",
    "Reversibility",
    "ProofDensity",
    "Risk",
    "Cost",
    "Scope",
    "Unsupported"
  ],
  "dimension_semantics": {
    "IG": {"meaning": "information gain from repository-grounded inspection", "orientation": "maximize"},
    "BV": {"meaning": "business and user value", "orientation": "maximize"},
    "N": {"meaning": "novelty of the candidate trajectory", "orientation": "maximize"},
    "Adj": {"meaning": "useful adjacency to the current boundary", "orientation": "maximize"},
    "CrossLens": {"meaning": "cross-lens resonance", "orientation": "maximize"},
    "FutureBug": {"meaning": "future-bug prevention or discovery yield", "orientation": "maximize"},
    "FeatureYield": {"meaning": "future feature possibility unlocked", "orientation": "maximize"},
    "ArchLeverage": {"meaning": "architecture leverage", "orientation": "maximize"},
    "VF": {"meaning": "verification feasibility", "orientation": "maximize"},
    "Testability": {"meaning": "behavioral testability", "orientation": "maximize"},
    "Reversibility": {"meaning": "implementation reversibility", "orientation": "maximize"},
    "ProofDensity": {"meaning": "independent proof obligations addressed per unit scope", "orientation": "maximize"},
    "Risk": {"meaning": "implementation and production risk", "orientation": "minimize"},
    "Cost": {"meaning": "implementation and operational cost", "orientation": "minimize"},
    "Scope": {"meaning": "implementation scope burden", "orientation": "minimize"},
    "Unsupported": {"meaning": "unsupported inference and unverifiability", "orientation": "minimize"}
  },
  "baseline_contracts": {
    "trace007": {
      "roles": {
        "positive_required": ["IG", "BV", "VF", "ProofDensity"],
        "positive_optional": ["Testability"],
        "penalty_required": ["Unsupported", "Scope"],
        "penalty_optional": ["Risk", "Cost"],
        "excluded": ["N", "Adj", "CrossLens", "FutureBug", "FeatureYield", "ArchLeverage", "Reversibility"]
      },
      "groups": {
        "positive": {
          "evidence": {"weight": 0.30, "dimensions": ["IG"]},
          "value": {"weight": 0.25, "dimensions": ["BV"]},
          "verification": {"weight": 0.25, "dimensions": ["VF", "Testability"]},
          "proof": {"weight": 0.20, "dimensions": ["ProofDensity"]}
        },
        "penalty": {
          "unsupported": {"weight": 0.35, "dimensions": ["Unsupported"]},
          "risk": {"weight": 0.30, "dimensions": ["Risk"]},
          "scope": {"weight": 0.20, "dimensions": ["Scope"]},
          "cost": {"weight": 0.15, "dimensions": ["Cost"]}
        }
      },
      "aggregation": "weighted_mean_of_available_dimensions_within_each_declared_group",
      "positive_group_weight_sum": 1.0,
      "penalty_group_weight_sum": 1.0,
      "schema_rule": "every score dimension is classified exactly once; required dimensions must exist; optional absence is reported; unclassified dimensions fail closed"
    }
  },
  "topology_contract": {
    "candidate_graph": {
      "vertices": "candidate trajectories",
      "relations": ["same concept", "shared implementation boundary", "recombination lineage", "semantic similarity", "common evidence"],
      "allowed_metrics": ["candidate edge touch", "separation", "redundancy", "search diversity"],
      "forbidden_claim": "software invariant completion"
    },
    "software_invariant_hypergraph": {
      "vertices": "actual software entities or obligations",
      "candidate_mapping": "candidates declare represented software vertices",
      "coverage": ["touch", "fractional", "complete", "proved"],
      "proved_rule": "complete representation plus accepted independent behavioral proof on the exact candidate"
    }
  },
  "feasible_domain": {
    "rule": "All objective variants and baselines use the same mandatory-coverage and invariant-feasible domain.",
    "mandatory_coverage": "constraint_not_objective_bonus"
  },
  "required_controls_T2_T3": ["full", "no_graph", "no_diversity", "evidence_baseline", "feasible_random"],
  "baseline_rules": {
    "membership": "declared explicitly; never inferred from names, aliases, weight signs, or whatever dimensions happen to exist",
    "orientation": "declared independently from objective weights",
    "schema_change": "a newly introduced unclassified score dimension fails with unclassified_baseline_dimensions",
    "grouping": "semantic group weights prevent schema density from changing baseline importance",
    "reporting": [
      "baseline_positive_used",
      "baseline_penalties_used",
      "baseline_optional_missing",
      "baseline_excluded",
      "same_feasible_domain",
      "selection_jaccard",
      "implementation_jaccard",
      "full_objective_difference",
      "independent_proof_yield_difference",
      "causal_improvement"
    ]
  },
  "causality": {
    "selection_influencing": "the term changes a selected candidate set inside the same feasible domain",
    "causal_improvement": "an equal-feasibility implementation ablation improves independent outcomes such as defects found, complete proof obligations, coherence, review defects, unnecessary scope, or executable verification yield",
    "default_without_ablation": "descriptive_or_selection_influencing",
    "forbidden_evidence": ["ranking difference alone", "objective delta alone", "candidate edge touch", "software node representation alone"]
  },
  "sensitivity": {
    "search": "report unique optima, objective spread, and selected-set stability across deterministic restarts",
    "weights": "report selected-set and software-coverage stability under declared bounded perturbations",
    "failure_rule": "instability is reported and reduces confidence; it is not hidden by choosing a favorable run"
  },
  "mathematics_guards": {
    "hypergraph": "separate candidate topology from software invariant topology",
    "hodge": "use only for a true simplicial complex",
    "koopman": "use only with repeated comparable trajectories, fitted propagation, held-out evaluation, and diversity or residual control",
    "predictive_models": "disabled when they do not outperform a simpler evidence-and-invariants baseline on held-out outcomes",
    "continuous_thought": "COCONUT, latent BFS, hidden-state recursion, manifold, or continuous-thought language is inspiration only unless executable implementation and verification exist",
    "unknown": "never coerce to observed, zero risk, or positive evidence"
  },
  "implementation_compression": {
    "separate_from_exploration": true,
    "must_preserve_invariants": true,
    "must_have_complete_behavioral_proof_plan_or_honest_blocker": true,
    "must_avoid_parallel_ontology_or_runtime": true,
    "must_minimize_unrelated_scope": true,
    "may_use_simple_baseline_when_math_is_noncausal": true
  },
  "required_trace_artifacts_T2_T3": [
    "task_state.json",
    "thought_templates.json",
    "candidate_population.json",
    "candidate_scores.json",
    "candidate_graph.json",
    "software_invariant_hypergraph.json",
    "selection_comparison.json",
    "selected_exploration.json",
    "selected_implementation.json",
    "implementation_ablation.json",
    "counterexample_matrix.json",
    "implementation_contract.json",
    "verification_plan.json",
    "decision_record.md",
    "deterministic_verifier"
  ],
  "evidence_nonpromotion": [
    "decision",
    "documentation",
    "source",
    "unit",
    "integration",
    "ci",
    "provider",
    "managed_database",
    "target_host",
    "browser_channel",
    "commercial",
    "signed_release",
    "pilot",
    "deployment",
    "production"
  ]
}
