{
  "name": "amtech-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "AMTECH AI Employee MVP — build home. Current plan: production-readiness-program/.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "generate:production-sources": "node apps/manager/scripts/generate-production-server.mjs && node apps/manager/scripts/patch-production-stream.mjs",
    "prepare": "npm run generate:production-sources",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run build --workspace @amtech/shared && npm run typecheck --workspace @amtech/shared && npm run build --workspace @amtech/db && npm run typecheck --workspace @amtech/db && npm run typecheck --workspace @amtech/manager && npm run typecheck --workspace @amtech/web",
    "lint": "npm run generate:production-sources && eslint . --ext .ts,.tsx",
    "test": "npm run test:unit",
    "test:unit": "npm run generate:production-sources && npm run build --workspace @amtech/shared && npm run build --workspace @amtech/db && vitest run",
    "test:integration": "npm run generate:production-sources && vitest run --config vitest.integration.config.ts",
    "test:remediation-plan": "vitest run tests/unit/remediation-plan-integrity.test.ts",
    "test:standard": "vitest run tests/unit/standard-ratification-contract.test.ts tests/unit/connector-registry.test.ts tests/unit/connector-setup.test.ts tests/unit/connector-capability-binding-contract.test.ts tests/unit/capability-drawer-setup-contract.test.ts --reporter=verbose",
    "test:repo-governance": "node scripts/verify-repository-governance.mjs",
    "repo:rubric": "node scripts/agent-task-rubric.mjs",
    "repo:verify:quick": "npm run test:standard && npm run test:remediation-plan && npm run test:repo-governance",
    "repo:verify:full": "npm run repo:verify:quick && npm run typecheck && npm run lint",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "hermes:upstream:check": "node scripts/check-hermes-upstream.mjs",
    "test:lane1-scope": "vitest run tests/unit/authorization-scope-registry.test.ts tests/unit/assignment-enforcement-contract.test.ts",
    "test:assignment-enforcement": "vitest run tests/unit/assignment-enforcement-contract.test.ts",
    "test:lane10-evidence": "vitest run tests/unit/release-evidence-contract.test.ts",
    "test:s10-onboarding": "npm run generate:production-sources && vitest run tests/unit/onboarding-identity-contract.test.ts",
    "test:ui:contracts": "npm run generate:production-sources && vitest run tests/unit/amtech-agent-ui-contract.test.ts tests/unit/ui-resources.test.ts tests/unit/ui-fixture-guard.test.ts tests/unit/observe-work-event-projection.test.ts tests/unit/web-operating-snapshot-contract.test.ts tests/unit/ws02-protocol-boundary.test.ts tests/unit/ws02-http-adapters.test.ts tests/unit/ws02-hardening-regressions.test.ts --reporter=verbose",
    "test:production-boundary": "npm run generate:production-sources && vitest run tests/unit/model-profile-isolation.test.ts tests/unit/model-gateway-http-isolation.test.ts tests/unit/ws07-commercial-admission.test.ts tests/unit/ws06-ws08-failure-manifold.test.ts tests/unit/provisioner-idempotency.test.ts tests/unit/ambient-inbox-contract.test.ts tests/unit/production-boundary-source.test.ts tests/unit/production-topology-acceptance.test.ts tests/unit/employee-stream-strict.test.ts tests/unit/web-operating-snapshot-contract.test.ts tests/unit/production-live-harness.test.ts tests/unit/s8-local-production-contract.test.ts tests/unit/sdrt-v2-contract.test.ts tests/unit/artifact-workbench-contract.test.ts tests/unit/ws02-protocol-boundary.test.ts tests/unit/ws02-http-adapters.test.ts tests/unit/ws02-hardening-regressions.test.ts",
    "test:ws07-ws08": "npm run generate:production-sources && vitest run tests/unit/ws07-commercial-admission.test.ts tests/unit/ws06-ws08-failure-manifold.test.ts tests/unit/model-gateway-http-isolation.test.ts && vitest run --config vitest.integration.config.ts tests/integration/ws07-commercial-ledger.test.ts",
    "test:worker-migrations": "vitest run --config vitest.integration.config.ts tests/integration/worker-migrations.test.ts",
    "test:watch": "vitest",
    "ui:validate": "node scripts/validate-ui-system.mjs",
    "release:evidence:spine": "node infra/scripts/acceptance/release-evidence-spine.mjs",
    "release:assignment-enforcement": "node infra/scripts/acceptance/assignment-enforcement-spine.mjs",
    "plugins:test": "python3 packages/agent-template/plugins/amtech-hygiene/test_hygiene.py",
    "db:migrate": "node packages/db/migrate.mjs",
    "db:status": "node packages/db/migrate.mjs --status",
    "db:verify:worker-migrations": "node infra/scripts/acceptance/verify-worker-migrations.mjs",
    "db:verify:commercial-effect-migrations": "node infra/scripts/acceptance/verify-commercial-effect-migrations.mjs",
    "manager:dev": "npm run dev --workspace @amtech/manager",
    "web:dev": "npm run dev --workspace @amtech/web",
    "scheduler:tick": "node infra/scripts/scheduler-tick.mjs",
    "scheduler:hermes-jobs": "node infra/scripts/hermes-jobs-runner.mjs",
    "local:check": "node infra/scripts/local/check.mjs",
    "local:inspect": "node infra/scripts/local/inspect.mjs",
