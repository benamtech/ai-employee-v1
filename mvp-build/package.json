    "prod-env:proof": "node infra/scripts/prod-env-proof.mjs",
    "capacity:pod-alpha": "node infra/scripts/capacity-pod-alpha.mjs",
    "deploy:smoke": "node infra/scripts/with-git-sha.mjs infra/scripts/deploy-smoke.mjs",
    "deploy:rollback": "node infra/scripts/with-git-sha.mjs infra/scripts/deploy-rollback.mjs",
    "prod:up": "node infra/scripts/with-git-sha.mjs infra/scripts/production-normal-up.mjs",
    "prod:normal:up": "node infra/scripts/with-git-sha.mjs infra/scripts/production-normal-up.mjs",
    "prod:vps:normal:up": "node infra/scripts/with-git-sha.mjs infra/scripts/production-normal-up.mjs --target=vps",
    "prod-like:public-estimator:up": "node infra/scripts/with-git-sha.mjs infra/scripts/prod-like-public-estimator-up.mjs",
    "prod-like:public-estimator:smoke": "node infra/scripts/public-estimator-smoke.mjs",
    "prod-like:down": "node infra/scripts/with-git-sha.mjs infra/scripts/prod-like-down.mjs",
    "prod-like:normal:up": "node infra/scripts/with-git-sha.mjs infra/scripts/prod-like-normal-employee-up.mjs",
    "prod-like:normal:down": "node infra/scripts/with-git-sha.mjs infra/scripts/prod-like-normal-employee-down.mjs",
    "prod-like:normal:browser-onboard": "node infra/scripts/local/acceptance/06-browser-onboard.mjs",
    "prod:onboarding-proof": "node infra/scripts/prod-onboarding-proof.mjs",
    "prod:normal:validate": "node infra/scripts/prod-normal-employee-validate.mjs",
    "prod:boundary:hermes-filesystem": "node infra/scripts/acceptance/hermes-exact-image-filesystem-proof.mjs",
    "prod:boundary:capabilities": "node infra/scripts/acceptance/effective-capability-live-proof.mjs",
    "prod:boundary:migrations": "node infra/scripts/acceptance/migration-staging-live-proof.mjs",
    "prod:boundary:gateway": "node infra/scripts/acceptance/model-gateway-live-proof.mjs",
    "prod:boundary:rotation": "node infra/scripts/acceptance/rotation-live-proof.mjs",
    "prod:boundary:recovery": "node infra/scripts/acceptance/reconciler-recovery-live-proof.mjs",
    "prod:boundary:ambient": "node infra/scripts/acceptance/ambient-ingress-live-proof.mjs",
    "prod:boundary:onboarding": "node infra/scripts/acceptance/canonical-browser-live-proof.mjs",
    "prod:boundary:work-object": "node infra/scripts/acceptance/generated-work-object-live-proof.mjs",
    "prod:boundary:isolation": "node infra/scripts/acceptance/target-host-two-employee-isolation.mjs",
    "prod:boundary:isolation:mutate": "node infra/scripts/acceptance/target-host-two-employee-isolation.mjs --mutate",
    "prod:boundary:validate": "node infra/scripts/acceptance/production-boundary-live.mjs",
    "prod-like:env:sync": "node infra/scripts/prod-env-overlay.mjs",
    "prod-like:tunnel:ensure": "node infra/scripts/prod-env-overlay.mjs ensure-tunnel",
    "live:up": "bash infra/scripts/local/test/stack-up.sh",
    "live:down": "bash infra/scripts/local/test/stack-down.sh",
