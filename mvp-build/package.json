{
  "name": "amtech-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "AMTECH AI Employee MVP — build home. Current plan: ../wiki/MVP/build-plan-current/.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "db:migrate": "node packages/db/migrate.mjs",
    "db:status": "node packages/db/migrate.mjs --status",
    "manager:dev": "npm run dev --workspace @amtech/manager",
    "web:dev": "npm run dev --workspace @amtech/web",
    "scheduler:tick": "node infra/scripts/scheduler-tick.mjs",
    "scheduler:hermes-jobs": "node infra/scripts/hermes-jobs-runner.mjs",
    "local:check": "node infra/scripts/local/check.mjs",
    "local:inspect": "node infra/scripts/local/inspect.mjs",
    "local:build-hermes": "node infra/scripts/local/build-hermes-image.mjs",
    "local:db-setup": "bash infra/scripts/local/db-setup.sh",
    "local:bootstrap": "node infra/scripts/local/bootstrap.mjs",
    "local:onboard": "node infra/scripts/local/onboard.mjs",
    "local:fixture": "node infra/scripts/local/contractor-fixtures.mjs",
    "local:model-bridge": "node infra/scripts/local/model-bridge.mjs",
    "local:model-bridge-worker": "node infra/scripts/local/model-bridge-worker.mjs",
    "local:chat": "node infra/scripts/local/chat.mjs",
    "local:tool-loop-proof": "node infra/scripts/local/tool-loop-proof.mjs",
    "local:acceptance:env": "node infra/scripts/local/acceptance/01-env.mjs",
    "local:acceptance:services": "node infra/scripts/local/acceptance/02-services.mjs",
    "local:acceptance:runtime": "node infra/scripts/local/acceptance/03-runtime.mjs",
    "local:acceptance:chat": "node infra/scripts/local/acceptance/04-chat.mjs",
    "local:acceptance:browser": "node infra/scripts/local/acceptance/05-browser.mjs",
    "local:acceptance:browser-onboard": "node infra/scripts/local/acceptance/06-browser-onboard.mjs",
    "local:acceptance": "node infra/scripts/local/acceptance/full-local.mjs",
    "local:browser-install": "playwright install chromium",
    "ui:dev": "NEXT_PUBLIC_AMTECH_UI_FIXTURES=1 next dev apps/web -p 3000 -H 127.0.0.1",
    "ui:browser": "node infra/scripts/ui/fixture-browser.mjs --headed --keep-open",
    "ui:test": "node infra/scripts/ui/fixture-browser.mjs",
    "ui:test:headed": "node infra/scripts/ui/fixture-browser.mjs --headed",
    "smoke:hermes": "node infra/scripts/hermes-smoke.mjs",
    "smoke:live-employee": "node infra/scripts/acceptance/run9-live-employee.mjs",
    "smoke:phase01": "node infra/scripts/acceptance/run2-provision.mjs",
    "acceptance:preflight": "node infra/scripts/acceptance/preflight.mjs",
    "acceptance:report": "node infra/scripts/acceptance/report.mjs",
    "ops:number-pool": "node infra/scripts/number-pool.mjs",
    "ops:healthcheck": "node infra/scripts/healthcheck.mjs",
    "ops:repair": "node infra/scripts/repair.mjs",
    "ops:employee-lifecycle": "node infra/scripts/employee-lifecycle.mjs",
    "ops:reprovision-scoped-mcp": "node infra/scripts/reprovision-scoped-mcp.mjs",
    "ops:caddy-proof": "node infra/scripts/caddy-proof.mjs",
    "ops:backup": "node infra/scripts/backup-restore.mjs backup",
    "ops:restore": "node infra/scripts/backup-restore.mjs restore",
    "ops:red-health": "node infra/scripts/red-health.mjs",
    "ops:egress-policy": "node infra/scripts/egress-policy.mjs",
    "capacity:pod-alpha": "node infra/scripts/capacity-pod-alpha.mjs",
    "deploy:smoke": "node infra/scripts/deploy-smoke.mjs",
    "deploy:rollback": "node infra/scripts/deploy-rollback.mjs",
    "live:up": "bash infra/scripts/local/test/stack-up.sh",
    "live:down": "bash infra/scripts/local/test/stack-down.sh",
    "live:status": "bash infra/scripts/local/test/status.sh",
    "live:list": "node infra/scripts/local/test/reprovision.mjs list",
    "live:reprovision": "node infra/scripts/local/test/reprovision.mjs from",
    "live:recover": "bash infra/scripts/local/test/employee-recover.sh",
    "live:login": "bash infra/scripts/local/test/devlogin.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
