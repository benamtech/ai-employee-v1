{
  "schema": "amtech.ws08-release-state-machine.v1",
  "states": [
    "source_selected",
    "images_building",
    "images_exact",
    "manifest_signed",
    "manifest_verified",
    "deploying",
    "healthy",
    "partial_topology",
    "fault_injected",
    "ambiguous",
    "repairing",
    "recovered",
    "backup_complete",
    "restoring",
    "restore_verified",
    "rollback_planned",
    "rolling_back",
    "rollback_verified",
    "blocked",
    "failed"
  ],
  "transitions": [
    {"from":"source_selected","action":"build_five_images","to":"images_building","requires":["exact_git_sha"]},
    {"from":"images_building","action":"inspect_distinct_ids_and_labels","to":"images_exact","requires":["five_distinct_image_ids","exact_revision_labels"]},
    {"from":"images_exact","action":"sign_canonical_manifest","to":"manifest_signed","requires":["compose_hash","config_hashes","migration_head","secret_version_refs"]},
    {"from":"manifest_signed","action":"independent_verify","to":"manifest_verified","requires":["public_key_fingerprint","signature","recomputed_hashes"]},
    {"from":"manifest_verified","action":"deploy","to":"deploying","requires":["five_service_release_unit"]},
    {"from":"deploying","action":"all_dependencies_healthy","to":"healthy","requires":["truthful_aggregate_health"]},
    {"from":"deploying","action":"one_service_missing_or_unhealthy","to":"partial_topology","requires":["no_false_success"]},
    {"from":"healthy","action":"deterministic_fault","to":"fault_injected","requires":["stable_crash_point","diagnostic_capture"]},
    {"from":"fault_injected","action":"outcome_unknown","to":"ambiguous","requires":["retry_blocked"]},
    {"from":"ambiguous","action":"reconcile_original_identity","to":"repairing","requires":["accepted_or_nonacceptance_proof"]},
    {"from":"repairing","action":"proof_refound_without_duplicate","to":"recovered","requires":["accepted_work_preserved"]},
    {"from":"healthy","action":"backup_database_filesystem_release_secrets","to":"backup_complete","requires":["bundle_digest","accepted_work_snapshot"]},
    {"from":"backup_complete","action":"restore_with_confirmation","to":"restoring","requires":["trusted_release_key","matching_secret_versions"]},
    {"from":"restoring","action":"verify_durable_truth_and_proof_refinding","to":"restore_verified","requires":["exact_counts","all_projected_proofs_refindable"]},
    {"from":"manifest_verified","action":"load_prior_signed_manifest","to":"rollback_planned","requires":["schema_compatibility"]},
    {"from":"rollback_planned","action":"apply_five_image_rollback","to":"rolling_back","requires":["explicit_apply","accepted_work_before"]},
    {"from":"rolling_back","action":"smoke_and_compare_accepted_work","to":"rollback_verified","requires":["five_services_healthy","accepted_work_unchanged"]}
  ],
  "forbidden_transitions": [
    "partial_topology -> healthy",
    "ambiguous -> automatic_retry",
    "accepted_effect -> duplicate_effect",
    "manifest_unsigned -> deployable_release",
    "floating_image -> signed_manifest",
    "restore_without_secret_versions -> restore_verified",
    "restore_without_proof_refinding -> restore_verified",
    "rollback_without_schema_compatibility -> rolling_back",
    "rollback_with_accepted_work_loss -> rollback_verified"
  ]
}
